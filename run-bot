#!/bin/bash
set -e

DETACH=
INTERACTIVE=
BOT_COUNT=4

for arg in "$@"; do
  case "$arg" in
    -i|--interactive) INTERACTIVE=1 ;;
    -d|--detach) DETACH=1 ;;
    [1-4]) BOT_COUNT="$arg" ;;
    -h|--help)
      echo "Usage: $0 [bot-count] [-d|--detach] [-i|--interactive]"
      echo "  bot-count       Number of parallel bots (1-4, default: 4)"
      echo "  -d, --detach    Run containers in background"
      echo "  -i, --interactive  Prompt for configuration"
      exit 0 ;;
  esac
done

if [ "$BOT_COUNT" -gt 4 ]; then
  echo "Max 4 bots supported. Using 4."
  BOT_COUNT=4
fi

cd "$(dirname "$0")"

echo "=========================================="
echo "  Overworld Visitor - ${BOT_COUNT} Bot(s)"
echo "=========================================="

# ----- Linux check -----
if [ "$(uname -s)" != "Linux" ]; then
  echo "This script is Linux-only. Detected: $(uname -s)"
  exit 1
fi

# ----- Install missing dependencies -----
if ! command -v docker &>/dev/null; then
  echo "[...] Installing Docker..."
  curl -fsSL https://get.docker.com | sh
  echo "[OK] Docker installed"
else
  echo "[OK] $(docker --version 2>/dev/null || echo 'docker')"
fi

if ! docker compose version &>/dev/null; then
  echo "[...] Installing Docker Compose plugin..."
  apt-get update -qq && apt-get install -y -qq docker-compose-plugin 2>/dev/null || \
  apk add docker-compose 2>/dev/null || true
fi
echo "[OK] $(docker compose version 2>/dev/null || echo 'docker compose')"

# ----- Setup .env -----
if [ ! -f .env ]; then
  echo "[...] Creating .env with defaults..."
  cat > .env << 'EOF'
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=Bot
MC_AUTH=offline
RENDER_DISTANCE=28
FLY_Y=200
GRID_STEP=160
BOT_COUNT=4
WORLD_PATH=./mc-data/world
WP_DELAY=2000
REGION_DELAY=2000
CHUNK_LOAD_TIMEOUT=30000
BLUEMAP_HOST=bluemap
BLUEMAP_PORT=8100
BLUEMAP_MAP=overworld
EOF
fi

# ----- Export env vars for compose -----
export BOT_COUNT
source .env
export MC_USERNAME WORLD_PATH FLY_Y GRID_STEP RENDER_DISTANCE WP_DELAY
export CHUNK_LOAD_TIMEOUT BLUEMAP_HOST BLUEMAP_PORT BLUEMAP_MAP

echo "  Bots:        ${BOT_COUNT}"
echo "  Username:    ${MC_USERNAME}"
echo "  World:       ${WORLD_PATH}"
echo "  Fly Y:       ${FLY_Y}"
echo "  Grid step:   ${GRID_STEP}"
echo ""

# ----- Fix world directory permissions -----
if [ -d "$WORLD_PATH" ]; then
  OWNER=$(stat -c '%u' "$WORLD_PATH" 2>/dev/null || echo "0")
  if [ "$OWNER" = "0" ]; then
    echo "[...] Fixing world directory ownership..."
    sudo chown -R 1000:1000 "$WORLD_PATH" 2>/dev/null || chown -R 1000:1000 "$WORLD_PATH" 2>/dev/null || true
  fi
fi

# ----- Interactive prompts -----
if [ -n "$INTERACTIVE" ]; then
  echo "--- Interactive Configuration ---"
  read -r -p "Bot username [${MC_USERNAME}]: " input
  MC_USERNAME="${input:-$MC_USERNAME}"
  read -r -p "World path [${WORLD_PATH}]: " input
  WORLD_PATH="${input:-$WORLD_PATH}"
  read -r -p "Flight Y altitude [${FLY_Y}]: " input
  FLY_Y="${input:-$FLY_Y}"
  read -r -p "Grid step (blocks) [${GRID_STEP}]: " input
  GRID_STEP="${input:-$GRID_STEP}"
  read -r -p "Render distance (chunks) [${RENDER_DISTANCE}]: " input
  RENDER_DISTANCE="${input:-$RENDER_DISTANCE}"
  read -r -p "BlueMap host [${BLUEMAP_HOST:-bluemap}]: " input
  BLUEMAP_HOST="${input:-${BLUEMAP_HOST:-bluemap}}"
  read -r -p "BlueMap port [${BLUEMAP_PORT:-8100}]: " input
  BLUEMAP_PORT="${input:-${BLUEMAP_PORT:-8100}}"
  read -r -p "BlueMap map [${BLUEMAP_MAP:-overworld}]: " input
  BLUEMAP_MAP="${input:-${BLUEMAP_MAP:-overworld}}"
  echo ""

  # Save to .env for future runs
  cat > .env << EOF
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=${MC_USERNAME}
MC_AUTH=offline
RENDER_DISTANCE=${RENDER_DISTANCE}
FLY_Y=${FLY_Y}
GRID_STEP=${GRID_STEP}
BOT_COUNT=${BOT_COUNT}
WORLD_PATH=${WORLD_PATH}
WP_DELAY=${WP_DELAY:-2000}
REGION_DELAY=${REGION_DELAY:-2000}
CHUNK_LOAD_TIMEOUT=${CHUNK_LOAD_TIMEOUT:-300000}
BLUEMAP_HOST=${BLUEMAP_HOST}
BLUEMAP_PORT=${BLUEMAP_PORT}
BLUEMAP_MAP=${BLUEMAP_MAP}
EOF

  echo "--- Launching with ---"
  echo "  Bots:        ${BOT_COUNT}"
  echo "  Username:    ${MC_USERNAME}"
  echo "  World:       ${WORLD_PATH}"
  echo "  Fly Y:       ${FLY_Y}"
  echo "  Grid step:   ${GRID_STEP}"
  echo "  Render dist: ${RENDER_DISTANCE}"
  echo ""
fi

# ----- Build bot image if needed -----
if ! docker image inspect world-visitor-bot-visitor &>/dev/null; then
  echo "[...] Building bot Docker image..."
  docker compose build visitor
  echo "[OK] Bot image built"
fi

# ----- Launch -----
if [ -n "$DETACH" ]; then
  echo "[...] Starting Minecraft server + ${BOT_COUNT} bot(s) + BlueMap..."
  echo "      Use 'docker compose logs -f' to follow output."
  echo "      Use 'docker compose stop' to stop."
  echo ""
  UP_FLAGS="-d"
else
  echo "[...] Starting Minecraft server + ${BOT_COUNT} bot(s) + BlueMap..."
  echo "     Press Ctrl+C to stop."
  echo ""
  UP_FLAGS="--abort-on-container-exit"
fi

case "$BOT_COUNT" in
  1)
    exec docker compose up $UP_FLAGS mc visitor bluemap
    ;;
  2)
    exec docker compose --profile multi up $UP_FLAGS mc visitor visitor1 bluemap
    ;;
  3)
    exec docker compose --profile multi up $UP_FLAGS mc visitor visitor1 visitor2 bluemap
    ;;
  4)
    exec docker compose --profile multi up $UP_FLAGS mc visitor visitor1 visitor2 visitor3 bluemap
    ;;
esac
