#!/bin/bash
set -e

DETACH=
BOT_COUNT=4

for arg in "$@"; do
  case "$arg" in
    -d|--detach) DETACH=1 ;;
    [1-4]) BOT_COUNT="$arg" ;;
  esac
done

if [ "$BOT_COUNT" -gt 4 ]; then
  echo "Max 4 bots supported. Using 4."
  BOT_COUNT=4
fi

cd "$(dirname "$0")"

echo "=========================================="
echo "  Overworld Visitor - ${BOT_COUNT} Bot(s)"
echo "=========================================="

# ----- Install missing dependencies -----
if ! command -v docker &>/dev/null; then
  echo "[...] Installing Docker..."
  curl -fsSL https://get.docker.com | sh
  echo "[OK] Docker installed"
else
  echo "[OK] $(docker --version 2>/dev/null || echo 'docker')"
fi

if ! docker compose version &>/dev/null; then
  echo "[...] Installing Docker Compose plugin..."
  apt-get update -qq && apt-get install -y -qq docker-compose-plugin 2>/dev/null || \
  apk add docker-compose 2>/dev/null || true
fi
echo "[OK] $(docker compose version 2>/dev/null || echo 'docker compose')"

# ----- Setup .env -----
if [ ! -f .env ]; then
  echo "[...] Creating .env with defaults..."
  cat > .env << 'EOF'
MC_HOST=localhost
MC_PORT=25565
MC_USERNAME=Bot
MC_AUTH=offline
RENDER_DISTANCE=28
FLY_Y=200
GRID_STEP=160
BOT_COUNT=4
WORLD_PATH=./world
WP_DELAY=2000
REGION_DELAY=2000
CHUNK_SETTLE_TIMEOUT=15000
CHUNK_SETTLE_COOLDOWN=1500
EOF
fi

# ----- Export env vars for compose -----
export BOT_COUNT
source .env
export MC_USERNAME WORLD_PATH FLY_Y GRID_STEP RENDER_DISTANCE WP_DELAY
export CHUNK_SETTLE_TIMEOUT CHUNK_SETTLE_COOLDOWN

echo "  Bots:        ${BOT_COUNT}"
echo "  Username:    ${MC_USERNAME}"
echo "  World:       ${WORLD_PATH}"
echo "  Fly Y:       ${FLY_Y}"
echo "  Grid step:   ${GRID_STEP}"
echo ""

# ----- Build bot image if needed -----
if ! docker image inspect world-visitor-bot-visitor &>/dev/null; then
  echo "[...] Building bot Docker image..."
  docker compose build visitor
  echo "[OK] Bot image built"
fi

# ----- Launch -----
if [ -n "$DETACH" ]; then
  echo "[...] Starting Minecraft server + ${BOT_COUNT} bot(s) in background..."
  echo "      Use 'docker compose logs -f' to follow output."
  echo "      Use 'docker compose stop' to stop."
  echo ""
  UP_FLAGS="-d"
else
  echo "[...] Starting Minecraft server + ${BOT_COUNT} bot(s)..."
  echo "     Press Ctrl+C to stop."
  echo ""
  UP_FLAGS="--abort-on-container-exit"
fi

case "$BOT_COUNT" in
  1)
    exec docker compose up $UP_FLAGS mc visitor
    ;;
  2)
    exec docker compose --profile multi up $UP_FLAGS mc visitor visitor1
    ;;
  3)
    exec docker compose --profile multi up $UP_FLAGS mc visitor visitor1 visitor2
    ;;
  4)
    exec docker compose --profile multi up $UP_FLAGS mc visitor visitor1 visitor2 visitor3
    ;;
esac
