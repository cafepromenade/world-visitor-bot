<Application x:Class="OverworldVisitor.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <materialDesign:BundledTheme BaseTheme="Dark" PrimaryColor="Teal" SecondaryColor="Amber" />
                <ResourceDictionary Source="pack://application:,,,/MaterialDesignThemes.Wpf;component/Themes/MaterialDesign3.Defaults.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <SolidColorBrush x:Key="BgDark" Color="#101418"/>
            <SolidColorBrush x:Key="BgMedium" Color="#171c22"/>
            <SolidColorBrush x:Key="BgLight" Color="#202832"/>
            <SolidColorBrush x:Key="BgControl" Color="#25303b"/>
            <SolidColorBrush x:Key="FgPrimary" Color="#f1f5f9"/>
            <SolidColorBrush x:Key="FgSecondary" Color="#a8b3bf"/>
            <SolidColorBrush x:Key="AccentGreen" Color="#00897b"/>
            <SolidColorBrush x:Key="AccentRed" Color="#c62828"/>
            <SolidColorBrush x:Key="AccentBlue" Color="#1976d2"/>
            <SolidColorBrush x:Key="AccentYellow" Color="#f9a825"/>
            <SolidColorBrush x:Key="BorderColor" Color="#33404c"/>

            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource BgDark}"/>
                <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
                <Setter Property="FontFamily" Value="Segoe UI"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="TextElement.Foreground" Value="{StaticResource FgPrimary}"/>
                <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
            </Style>

            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="Padding" Value="0,2"/>
            </Style>

            <Style TargetType="RadioButton">
                <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="Margin" Value="0,0,8,0"/>
            </Style>

            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
                <Setter Property="FontSize" Value="12"/>
            </Style>

            <Style TargetType="GroupBox">
                <Setter Property="Foreground" Value="{StaticResource FgSecondary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource BorderColor}"/>
                <Setter Property="FontSize" Value="12"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="materialDesign:ElevationAssist.Elevation" Value="Dp2"/>
            </Style>

            <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{StaticResource AccentGreen}"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>

            <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{StaticResource AccentRed}"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style x:Key="ActionButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
                <Setter Property="Background" Value="{StaticResource AccentBlue}"/>
                <Setter Property="Foreground" Value="White"/>
            </Style>

            <Style x:Key="StatLabel" TargetType="Label" BasedOn="{StaticResource {x:Type Label}}">
                <Setter Property="Foreground" Value="{StaticResource FgPrimary}"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
